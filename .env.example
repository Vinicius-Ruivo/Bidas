NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Chat (Google Gemini) — só no servidor; não use prefixo NEXT_PUBLIC
GEMINI_API_KEY=...
# Opcional (sem isto, o app tenta: gemini-2.5-flash → gemini-2.5-flash-lite → gemini-flash-latest)
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Opcional — leitura em voz alta “natural” (TTS Gemini). Padrão: gemini-2.5-flash-preview-tts
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
